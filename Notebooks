      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 7b. LAG-CORRELATION ANALYSIS\n",
        "#     Does HRV (and HR, SpO2) at lag 1-7 days correlate more strongly\n",
        "#     with next-night outcomes than the same-day (lag 0) values used\n",
        "#     in the models? Tests RQ3 more directly than a single same-day r.\n",
        "# ============================================================\n",
        "from scipy.stats import pearsonr\n",
        "\n",
        "lag_targets = {\n",
        "    \"Sleep Time Ratio(%)\": \"Sleep Time Ratio(%)\",\n",
        "    \"Deep Sleep(min)\": \"Sleep Stages - Deep Sleep(min)\",\n",
        "    \"WASO / Awake(min)\": \"Sleep Stages - Awake(min)\",\n",
        "}\n",
        "lag_predictors = {\n",
        "    \"Avg. HRV_Relative\": \"Avg. HRV(ms)_Relative\",\n",
        "    \"Avg. HR_Relative\": \"Avg. Heart Rate(bpm)_Relative\",\n",
        "    \"Avg. SpO2_Relative\": \"Avg. Spo2(%)_Relative\",\n",
        "}\n",
        "max_lag = 7\n",
        "lag_results = {t: {p: [] for p in lag_predictors} for t in lag_targets}\n",
        "lag_pvals = {t: {p: [] for p in lag_predictors} for t in lag_targets}\n",
        "\n",
        "for tname, tcol in lag_targets.items():\n",
        "    for pname, pcol in lag_predictors.items():\n",
        "        for lag in range(0, max_lag + 1):\n",
        "            shifted = final_df[pcol].shift(lag)\n",
        "            valid = shifted.notna() & final_df[tcol].notna()\n",
        "            if valid.sum() > 10:\n",
        "                r, p = pearsonr(shifted[valid], final_df[tcol][valid])\n",
        "            else:\n",
        "                r, p = np.nan, np.nan\n",
        "            lag_results[tname][pname].append(r)\n",
        "            lag_pvals[tname][pname].append(p)\n",
        "\n",
        "fig, axes = plt.subplots(1, 3, figsize=(15, 4.2))\n",
        "colors = {\"Avg. HRV_Relative\": \"#065A82\", \"Avg. HR_Relative\": \"#F96167\", \"Avg. SpO2_Relative\": \"#21295C\"}\n",
        "for ax, (tname, preds) in zip(axes, lag_results.items()):\n",
        "    for pname, rvals in preds.items():\n",
        "        ax.plot(range(0, max_lag + 1), rvals, marker='o', label=pname, color=colors[pname])\n",
        "    ax.axhline(0, color='grey', lw=0.8)\n",
        "    ax.axvline(0, color='orange', ls='--', lw=1, label='lag 0 (used in models)')\n",
        "    ax.set_title(tname)\n",
        "    ax.set_xlabel(\"Lag (days)\")\n",
        "    ax.set_ylabel(\"Pearson r\")\n",
        "axes[0].legend(fontsize=8)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "for tname in lag_targets:\n",
        "    rvals = lag_results[tname][\"Avg. HRV_Relative\"]\n",
        "    pvals = lag_pvals[tname][\"Avg. HRV_Relative\"]\n",
        "    best_lag = int(np.nanargmax(np.abs(rvals)))\n",
        "    print(f\"[LAG] {tname}: HRV strongest at lag {best_lag} (r={rvals[best_lag]:.3f}, \"\n",
        "          f\"p={pvals[best_lag]:.3f}); lag-0 r={rvals[0]:.3f} (p={pvals[0]:.3f})\")"
      ],
