    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 6. FINAL MERGE & MISSING DATA HANDLING\n",
        "# ============================================================\n",
        "activity_clean['Date'] = pd.to_datetime(activity_clean['Date']).dt.date\n",
        "vitals_clean['Date'] = pd.to_datetime(vitals_clean['Date']).dt.date\n",
        "\n",
        "final_df = activity_clean.merge(vitals_clean, on='Date').merge(sleep_clean, on='Date')\n",
        "\n",
        "final_df['Date'] = pd.to_datetime(final_df['Date'])\n",
        "final_df = final_df.sort_values('Date').reset_index(drop=True)   # chronological order, required before rolling()\n",
        "\n",
        "n_missing_before = final_df.isna().sum().sum()\n",
        "final_df = final_df.fillna(final_df.median(numeric_only=True))\n",
        "print(f\"[AUDIT] Merged days: {len(final_df)} | missing values imputed (median): {n_missing_before}\")"
      ],
