        "# ============================================================\n",
        "# 9. MODELING PIPELINE AS A REUSABLE FUNCTION\n",
        "#    (identical logic to the single-target fixed script, parameterized\n",
        "#     by target column so it can be run once per research question)\n",
        "# ============================================================\n",
        "from sklearn.preprocessing import StandardScaler, MinMaxScaler\n",
        "from sklearn.model_selection import GridSearchCV, TimeSeriesSplit, cross_val_score\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.metrics import mean_absolute_error, r2_score, mean_squared_error\n",
        "import shap\n",
        "import tensorflow as tf\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import LSTM, Dense, Dropout\n",
        "\n",
        "def create_sequences(data, target_arr, window_size=3):\n",
        "    Xs, ys = [], []\n",
        "    for i in range(len(data) - window_size):\n",
        "        Xs.append(data[i:(i + window_size)])\n",
        "        ys.append(target_arr[i + window_size])\n",
        "    return np.array(Xs), np.array(ys)\n",
        "\n",
        "def run_modeling_pipeline(df, features, target_col, label):\n",
        "    \"\"\"Runs RF (GridSearch+TimeSeriesSplit CV) + SHAP + LSTM for one target.\n",
        "    Returns a dict of results and prints an audit trail for the report.\"\"\"\n",
        "\n",
        "    print(f\"\\n{'='*60}\\nRUNNING PIPELINE FOR TARGET: {target_col}  ({label})\\n{'='*60}\")\n",
        "\n",
        "    X = df[features].values\n",
        "    y = df[target_col].values\n",
        "\n",
        "    # --- Chronological split ---\n",
        "    split_idx = int(len(df) * 0.8)\n",
        "    X_train, X_test = X[:split_idx], X[split_idx:]\n",
        "    y_train, y_test = y[:split_idx], y[split_idx:]\n",
        "    print(f\"[AUDIT-{label}] Train days: {len(X_train)} | Test days: {len(X_test)}\")\n",
        "\n",
        "    # --- Scale: fit on TRAIN only ---\n",
        "    scaler = StandardScaler()\n",
        "    X_train_scaled = scaler.fit_transform(X_train)\n",
        "    X_test_scaled = scaler.transform(X_test)\n",
        "\n",
        "    # --- Correlation heatmap on TRAIN portion only ---\n",
        "    train_df = df.iloc[:split_idx]\n",
        "    corr_cols = features + [target_col]\n",
        "    plt.figure(figsize=(10, 8))\n",
        "    sns.heatmap(train_df[corr_cols].corr(), annot=True, cmap='RdYlGn', center=0)\n",
        "    plt.title(f\"Correlation (Training Set): Relative Features vs. {target_col}\")\n",
        "    plt.show()\n",
        "\n",
        "    # --- Random Forest with TimeSeriesSplit CV ---\n",
        "    tscv = TimeSeriesSplit(n_splits=5)\n",
        "    param_grid = {\n",
        "        'n_estimators': [100, 200],\n",
        "        'max_depth': [None, 10, 20],\n",
        "        'min_samples_split': [2, 5],\n",
        "        'max_features': ['sqrt', 'log2']\n",
        "    }\n",
        "    grid_search = GridSearchCV(RandomForestRegressor(random_state=42),\n",
        "                                param_grid, cv=tscv, scoring='neg_mean_absolute_error')\n",
        "    grid_search.fit(X_train_scaled, y_train)\n",
        "    best_rf = grid_search.best_estimator_\n",
        "    print(f\"[RF-{label}] Best Parameters: {grid_search.best_params_}\")\n",
        "\n",
        "    cv_scores = -cross_val_score(best_rf, X_train_scaled, y_train, cv=tscv, scoring='neg_mean_absolute_error')\n",
        "    print(f\"[RF-{label}] CV MAE (train folds): {cv_scores.mean():.2f} (+/- {cv_scores.std():.2f})\")\n",
        "\n",
        "    y_pred_rf = best_rf.predict(X_test_scaled)\n",
        "    rf_mae = mean_absolute_error(y_test, y_pred_rf)\n",
        "    rf_rmse = np.sqrt(mean_squared_error(y_test, y_pred_rf))\n",
        "    rf_r2 = r2_score(y_test, y_pred_rf)\n",
        "    rf_mape = np.mean(np.abs((y_test - y_pred_rf) / (y_test + 1e-10))) * 100\n",
        "    print(f\"[RF-{label}] Test MAE: {rf_mae:.2f} | Test R2: {rf_r2:.3f} | Test RMSE: {rf_rmse:.2f} | Test MAPE: {rf_mape:.2f}%\")\n",
        "\n",
        "    # Bootstrap 95% CI\n",
        "    n_boot = 1000\n",
        "    rng = np.random.default_rng(42)\n",
        "    boot_maes = [mean_absolute_error(y_test[idx], y_pred_rf[idx])\n",
        "                 for idx in (rng.integers(0, len(y_test), len(y_test)) for _ in range(n_boot))]\n",
        "    ci_low, ci_high = np.percentile(boot_maes, [2.5, 97.5])\n",
        "    print(f\"[RF-{label}] Bootstrap 95% CI for MAE: [{ci_low:.2f}, {ci_high:.2f}]\")\n",
        "\n",
        "    plt.figure(figsize=(7, 5))\n",
        "    plt.scatter(y_test, y_pred_rf, alpha=0.6, color='darkblue')\n",
        "    plt.plot([y.min(), y.max()], [y.min(), y.max()], 'r--', lw=2)\n",
        "    plt.xlabel(f\"Actual {target_col}\")\n",
        "    plt.ylabel(f\"Predicted {target_col}\")\n",
        "    plt.title(f\"RF Diagnostic ({label}): Actual vs Predicted (R2: {rf_r2:.3f})\")\n",
        "    plt.show()\n",
        "\n",
        "    # --- SHAP ---\n",
        "    explainer = shap.TreeExplainer(best_rf)\n",
        "    shap_values = explainer.shap_values(X_test_scaled)\n",
        "    plt.figure()\n",
        "    shap.summary_plot(shap_values, X_test_scaled, feature_names=features, show=False)\n",
        "    plt.title(f\"SHAP Summary ({label})\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    importances = pd.Series(best_rf.feature_importances_, index=features).sort_values(ascending=True)\n",
        "    plt.figure(figsize=(9, 5))\n",
        "    importances.plot(kind='barh', color='teal')\n",
        "    plt.title(f\"Global Feature Importance - RF ({label})\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # ============================================================\n",
        "    # --- LSTM (with detailed summary) ---\n",
        "    # ============================================================\n",
        "    print(f\"\\n[LSTM-{label}] Training LSTM model...\")\n",
        "\n",
        "    scaler_x = MinMaxScaler()\n",
        "    scaler_y = MinMaxScaler()\n",
        "    X_train_dl_raw = scaler_x.fit_transform(X_train)\n",
        "    X_test_dl_raw = scaler_x.transform(X_test)\n",
        "    y_train_dl_raw = scaler_y.fit_transform(y_train.reshape(-1, 1))\n",
        "    y_test_dl_raw = scaler_y.transform(y_test.reshape(-1, 1))\n",
        "\n",
        "    window = 3\n",
        "    X_train_seq, y_train_seq = create_sequences(X_train_dl_raw, y_train_dl_raw, window_size=window)\n",
        "    X_test_seq, y_test_seq = create_sequences(X_test_dl_raw, y_test_dl_raw, window_size=window)\n",
        "\n",
        "    print(f\"[LSTM-{label}] Sequence shapes: Train {X_train_seq.shape}, Test {X_test_seq.shape}\")\n",
        "\n",
        "    dl_model = Sequential([\n",
        "        LSTM(50, activation='relu', input_shape=(window, X_train_seq.shape[2]), return_sequences=False),\n",
        "        Dropout(0.2),\n",
        "        Dense(25, activation='relu'),\n",
        "        Dense(1)\n",
        "    ])\n",
        "    dl_model.compile(optimizer='adam', loss='mse')\n",
        "\n",
        "    # Add verbose=1 to see training progress\n",
        "    history = dl_model.fit(X_train_seq, y_train_seq, epochs=50, batch_size=8,\n",
        "                            validation_split=0.1, verbose=1)  # Changed to verbose=1\n",
        "\n",
        "    y_pred_dl = dl_model.predict(X_test_seq)\n",
        "    y_pred_dl_final = scaler_y.inverse_transform(y_pred_dl)\n",
        "    y_test_dl_final = scaler_y.inverse_transform(y_test_seq)\n",
        "\n",
        "    dl_mae = mean_absolute_error(y_test_dl_final, y_pred_dl_final)\n",
        "    dl_r2 = r2_score(y_test_dl_final, y_pred_dl_final)\n",
        "    dl_rmse = np.sqrt(mean_squared_error(y_test_dl_final, y_pred_dl_final))\n",
        "    dl_mape = np.mean(np.abs((y_test_dl_final - y_pred_dl_final) / (y_test_dl_final + 1e-10))) * 100\n",
        "\n",
        "    print(f\"[LSTM-{label}] MAE: {dl_mae:.2f} | R2: {dl_r2:.4f} | RMSE: {dl_rmse:.2f} | MAPE: {dl_mape:.2f}%\")\n",
        "\n",
        "    # --- LSTM Training Loss Plot ---\n",
        "    plt.figure(figsize=(10, 6))\n",
        "    plt.plot(history.history['loss'], label='Training Loss', linewidth=2)\n",
        "    plt.plot(history.history['val_loss'], label='Validation Loss', linewidth=2)\n",
        "    plt.title(f\"LSTM Training Loss ({label})\", fontsize=12, fontweight='bold')\n",
        "    plt.xlabel('Epoch', fontsize=10)\n",
        "    plt.ylabel('Loss (MSE)', fontsize=10)\n",
        "    plt.legend()\n",
        "    plt.grid(True, alpha=0.3)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # --- LSTM Actual vs Predicted Plot ---\n",
        "    plt.figure(figsize=(7, 5))\n",
        "    plt.scatter(y_test_dl_final, y_pred_dl_final, alpha=0.6, color='darkgreen')\n",
        "    plt.plot([y_test_dl_final.min(), y_test_dl_final.max()],\n",
        "             [y_test_dl_final.min(), y_test_dl_final.max()], 'r--', lw=2)\n",
        "    plt.xlabel(f\"Actual {target_col}\")\n",
        "    plt.ylabel(f\"Predicted {target_col}\")\n",
        "    plt.title(f\"LSTM Diagnostic ({label}): Actual vs Predicted (R2: {dl_r2:.3f})\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # ============================================================\n",
        "    # --- LSTM SUMMARY TABLE (printed) ---\n",
        "    # ============================================================\n",
        "    print(f\"\\n{'='*60}\")\n",
        "    print(f\"LSTM SUMMARY - {label}\")\n",
        "    print(f\"{'='*60}\")\n",
        "    print(f\"Model Architecture:\")\n",
        "    print(f\"  - LSTM Units: 50\")\n",
        "    print(f\"  - Dropout Rate: 0.2\")\n",
        "    print(f\"  - Dense Units: 25\")\n",
        "    print(f\"  - Window Size: {window} days\")\n",
        "    print(f\"  - Epochs: 50\")\n",
        "    print(f\"  - Batch Size: 8\")\n",
        "    print(f\"  - Optimizer: Adam\")\n",
        "    print(f\"  - Loss Function: Mean Squared Error\")\n",
        "    print(f\"\\nTraining Data:\")\n",
        "    print(f\"  - Training sequences: {len(X_train_seq)}\")\n",
        "    print(f\"  - Test sequences: {len(X_test_seq)}\")\n",
        "    print(f\"  - Validation split: 10%\")\n",
        "    print(f\"\\nPerformance Metrics:\")\n",
        "    print(f\"  - MAE: {dl_mae:.2f}\")\n",
        "    print(f\"  - RMSE: {dl_rmse:.2f}\")\n",
        "    print(f\"  - R²: {dl_r2:.4f}\")\n",
        "    print(f\"  - MAPE: {dl_mape:.2f}%\")\n",
        "    print(f\"{'='*60}\\n\")\n",
        "\n",
        "    # Return all results including LSTM details\n",
        "    return {\n",
        "        'target': target_col,\n",
        "        'label': label,\n",
        "        'rf_mae': rf_mae,\n",
        "        'rf_r2': rf_r2,\n",
        "        'rf_ci': (ci_low, ci_high),\n",
        "        'rf_rmse': rf_rmse,\n",
        "        'rf_mape': rf_mape,\n",
