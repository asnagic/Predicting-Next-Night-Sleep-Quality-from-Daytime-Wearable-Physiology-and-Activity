    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 7. BASELINE-RELATIVE (7-DAY ROLLING) FEATURES - shared by both targets\n",
        "# ============================================================\n",
        "features_to_normalize = ['Avg. HRV(ms)', 'Avg. Heart Rate(bpm)', 'Steps', 'Calories(kcal)', 'Avg. Spo2(%)']\n",
        "\n",
        "for feature in features_to_normalize:\n",
        "    final_df[f'{feature}_7day_avg'] = final_df[feature].rolling(window=7, min_periods=1).mean()\n",
        "    final_df[f'{feature}_Relative'] = final_df[feature] - final_df[f'{feature}_7day_avg']\n",
        "\n",
        "FEATURES = [f'{f}_Relative' for f in features_to_normalize] + ['Sleep_Latency_Min']"
      ],
      "metadata": {
