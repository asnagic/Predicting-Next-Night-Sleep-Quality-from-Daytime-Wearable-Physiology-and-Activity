        "# -*- coding: utf-8 -*-\n",
        "\"\"\"\n",
        "Sleep Quality Prediction Pipeline - DUAL TARGET VERSION\n",
        "=========================================================\n",
        "Runs the full modeling + validation + XAI pipeline for BOTH outcomes\n",
        "named in the research questions:\n",
        "  Target A: 'Sleep Time Ratio(%)'          (sleep efficiency)\n",
        "  Target B: 'Sleep Stages - Deep Sleep(min)' (deep sleep duration)\n",
        "\n",
        "Preprocessing (loading, cleaning, outlier removal, merge, baseline-relative\n",
        "features) is done ONCE and shared. Modeling (RF + LSTM + SHAP + bootstrap CI)\n",
        "is then run separately per target via run_modeling_pipeline(), so both\n",
        "research questions get a complete, comparable result set.\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# ============================================================\n",
        "# 1. LOAD DATA\n",
        "# ============================================================\n",
        "try:\n",
        "    sleep_df = pd.read_csv('/content/drive/MyDrive/mlpr cda_proj/DATA/Sleep-Didiconn-2025-11-01-2026-05-04.csv')\n",
        "    vitals_df = pd.read_csv('/content/drive/MyDrive/mlpr cda_proj/DATA/Vital Signs-Didiconn-2025-11-01-2026-05-04.csv')\n",
        "    activity_df = pd.read_csv('/content/drive/MyDrive/mlpr cda_proj/DATA/Activity-Didiconn-2025-11-01-2026-05-04.csv')\n",
        "    print(\"Files loaded successfully!\")\n",
        "except FileNotFoundError:\n",
        "    print(\"Error: Check your folder name or file names in Google Drive.\")\n",
        "\n",
        "print(f\"[AUDIT] Raw sleep records: {len(sleep_df)}\")\n",
        "print(f\"[AUDIT] Raw vitals records: {len(vitals_df)}\")\n",
        "print(f\"[AUDIT] Raw activity records: {len(activity_df)}\")\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 2. INITIAL CLEANING\n",
        "# ============================================================\n",
        "def clean_numeric(df, columns):\n",
        "    for col in columns:\n",
        "        if df[col].dtype == 'object':\n",
        "            df[col] = df[col].str.replace('%', '').str.replace(',', '')\n",
        "        df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "    return df\n",
        "\n",
        "vitals_cols = ['Avg. Heart Rate(bpm)', 'Min. Heart Rate(bpm)', 'Max. Heart Rate(bpm)',\n",
        "               'Avg. Spo2(%)', 'Min. Spo2(%)', 'Max. Spo2(%)', 'Avg. HRV(ms)']\n",
        "vitals_df = clean_numeric(vitals_df, vitals_cols)\n",
        "\n",
        "sleep_cols = ['Sleep Time Ratio(%)', 'Time Asleep(min)', 'Sleep Stages - Awake(min)',\n",
        "              'Sleep Stages - REM(min)', 'Sleep Stages - Light Sleep(min)', 'Sleep Stages - Deep Sleep(min)']\n",
        "sleep_df = clean_numeric(sleep_df, sleep_cols)"
      ],
      "metadata": {
        "id": "xakDsm3PabQy"
      },
      "execution_count": 24,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 3. HANDLING DUPLICATES (daily aggregation)\n",
        "# ============================================================\n",
        "sleep_df['Date'] = pd.to_datetime(sleep_df['Start Time']).dt.date\n",
        "sleep_clean = sleep_df.groupby('Date').agg({\n",
        "    'Time Asleep(min)': 'sum',\n",
        "    'Sleep Stages - Awake(min)': 'sum',\n",
        "    'Sleep Stages - REM(min)': 'sum',\n",
        "    'Sleep Stages - Light Sleep(min)': 'sum',\n",
        "    'Sleep Stages - Deep Sleep(min)': 'sum',\n",
        "    'Sleep Time Ratio(%)': 'mean'\n",
        "}).reset_index()"
      ],
      "metadata": {
        "id": "N7oozQVkaeFc"
      },
      "execution_count": 25,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 4. FEATURE ENGINEERING: Sleep Latency\n",
        "# ============================================================\n",
        "sleep_df['Start Time'] = pd.to_datetime(sleep_df['Start Time'])\n",
        "sleep_df['Falling Asleep Time'] = pd.to_datetime(sleep_df['Falling Asleep Time'])\n",
        "sleep_df['Sleep_Latency_Min'] = (sleep_df['Falling Asleep Time'] - sleep_df['Start Time']).dt.total_seconds() / 60\n",
        "\n",
        "latency_df = sleep_df.groupby('Date')['Sleep_Latency_Min'].mean().reset_index()\n",
        "sleep_clean = pd.merge(sleep_clean, latency_df, on='Date')\n",
        "\n",
        "# ============================================================\n",
        "# 5. OUTLIER DETECTION & REMOVAL (IQR, consistent across predictors)\n",
        "# ============================================================\n",
        "def remove_outliers(df, columns):\n",
        "    mask = pd.Series(True, index=df.index)\n",
        "    for column in columns:\n",
        "        Q1 = df[column].quantile(0.25)\n",
        "        Q3 = df[column].quantile(0.75)\n",
        "        IQR = Q3 - Q1\n",
        "        lower_bound = Q1 - 1.5 * IQR\n",
        "        upper_bound = Q3 + 1.5 * IQR\n",
        "        mask &= df[column].between(lower_bound, upper_bound)\n",
        "    removed = (~mask).sum()\n",
        "    print(f\"[AUDIT] Outlier removal on {columns}: removed {removed} rows\")\n",
        "    return df[mask].copy()\n",
        "\n",
        "vitals_outlier_cols = ['Avg. HRV(ms)', 'Avg. Heart Rate(bpm)', 'Avg. Spo2(%)']\n",
        "vitals_clean = remove_outliers(vitals_df, vitals_outlier_cols)\n",
        "\n",
        "activity_outlier_cols = ['Steps', 'Calories(kcal)']\n",
        "activity_clean = remove_outliers(activity_df, [c for c in activity_outlier_cols if c in activity_df.columns])"
      ],
